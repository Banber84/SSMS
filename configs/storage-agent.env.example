# Server Storage Management System Agent systemd 环境变量示例
#
# 安装位置建议：
#   sudo install -m 0644 configs/storage-agent.env.example /etc/ssms/storage-agent.env
#   sudo vim /etc/ssms/storage-agent.env

# 管理后台地址，必须填写。
# 示例：SSMS_SERVER_URL=http://192.168.1.187:8080
SSMS_SERVER_URL=

# 当前节点名称，必须填写。三台服务机应分别设置为 MainNode、NodeA、NodeB 等。
SSMS_AGENT_NAME=

# 当前节点 IP，必须填写。
SSMS_AGENT_ADDRESS=

# 需要统计磁盘使用率的路径。
SSMS_AGENT_DISK=/

# 上报间隔。
SSMS_AGENT_INTERVAL=30s
