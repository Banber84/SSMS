# Server Storage Management System 统一部署模板
#
# 使用方式：
#   cp configs/site.env.example configs/site.env
#   vim configs/site.env
#   scripts/apply_site_config.sh --config configs/site.env --output-dir configs
#
# 如果要直接生成到系统配置目录：
#   sudo scripts/apply_site_config.sh --config configs/site.env --output-dir /etc/ssms

# 管理后台访问地址。
SSMS_MANAGEMENT_HOST="192.168.1.187"
SSMS_MANAGEMENT_PORT="8080"
SSMS_MANAGEMENT_URL="http://${SSMS_MANAGEMENT_HOST}:${SSMS_MANAGEMENT_PORT}"

# 管理后台 systemd 运行参数。
SSMS_SERVER_ADDR="0.0.0.0:${SSMS_MANAGEMENT_PORT}"
SSMS_DB_PATH="/var/lib/ssms/server-storage.db"
GIN_MODE="release"

# Storage Server 与 Samba 配置。
# 如果管理后台和 Storage Server 同机，保持 STORAGE_SERVER 等于 SSMS_MANAGEMENT_HOST。
STORAGE_SERVER="${SSMS_MANAGEMENT_HOST}"
STORAGE_ROOT="/srv/samba/users"
STORAGE_GROUP="storageusers"
DEFAULT_QUOTA_GB="10"
MOUNT_POINT_NAME="storage"
SMB_WORKGROUP="WORKGROUP"
SMB_NETBIOS_NAME="SSMS-STORAGE"

# 登录节点向 Storage Server 发起用户同步时使用的 SSH 配置。
STORAGE_SYNC_HOST="${STORAGE_SERVER}"
STORAGE_SYNC_USER="a2"
STORAGE_SYNC_PROJECT_DIR="/home/a2/ServerStorageManagementSystem"
DEFAULT_SYNC_QUOTA_GB="1"

# 当前机器 Agent 配置。每台机器部署时分别修改 name/address。
SSMS_AGENT_NAME="NodeA"
SSMS_AGENT_ADDRESS="192.168.1.188"
SSMS_AGENT_DISK="/"
SSMS_AGENT_INTERVAL="30s"

# Storage Server 批量同步登录节点用户时使用的节点清单。
# 格式：节点名 主机地址 SSH用户 项目目录
SSMS_NODES="
NodeA 192.168.1.122 nodea1 /home/nodea1/ServerStorageManagementSystem
NodeB 192.168.1.125 nodeb1 /home/nodeb1/ServerStorageManagementSystem
"
